rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - name: string (required, length < 100)
    //   - ownerId: string (required, immutable)
    //   - columns: list (required, length < 50)
    //   - tasks: list (required, length < 1000)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - createdAt: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
       return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    
    function uidUnchanged() {
       return !('ownerId' in request.resource.data) ||
         request.resource.data.ownerId == request.auth.uid;
    }
    
    function uidNotModified() {
       return !('ownerId' in request.resource.data) ||
         request.resource.data.ownerId == resource.data.ownerId;
    }
    
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
       return request.resource.data[field] is string &&
         request.resource.data[field].size() >= minLen &&
         request.resource.data[field].size() <= maxLen;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId', 'columns', 'tasks']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() < 50 &&
             data.columns is list && data.columns.size() <= 50 &&
             data.tasks is list && data.tasks.size() <= 1000;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && isValidProject(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
